{
  "name": "@pops/monorepo",
  "private": true,
  "scripts": {
    "dev": "mise run dev",
    "build": "tsc -b tsconfig.build.json",
    "typecheck": "mise run typecheck",
    "test": "mise run test",
    "test:coverage": "mise run test:coverage",
    "lint": "oxlint --type-aware",
    "lint:fix": "oxlint --type-aware --fix",
    "lint:boundaries": "depcruise --config .dependency-cruiser.cjs --ignore-known --output-type err pillars libs scripts",
    "lint:boundaries:baseline": "depcruise --config .dependency-cruiser.cjs --output-type baseline --output-to .dependency-cruiser-known-violations.json pillars libs scripts",
    "extractability:deps": "bash scripts/extractability/check-changed-units.sh",
    "extractability:deps:all": "node scripts/extractability/depcheck.mjs --all",
    "extractability:deps:self-test": "node scripts/extractability/depcheck.mjs --self-test",
    "extractability:baseline": "bash scripts/extractability/baseline-guard.sh",
    "extractability:sandbox": "bash scripts/extractability/sandbox.sh",
    "isolation:check": "pnpm lint:boundaries && pnpm extractability:baseline && pnpm extractability:deps && bash scripts/extractability/optional-gates.sh",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "exports:check": "node scripts/check-exports.mjs",
    "check:bundle-map": "node scripts/check-bundle-map-coverage.mjs",
    "check:bundle-map:self-test": "node scripts/check-bundle-map-coverage.mjs --self-test",
    "ci:fix": "pnpm lint:fix && pnpm format && pnpm typecheck",
    "registry:build": "pnpm --filter @pops/module-registry registry:build",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "dependency-cruiser": "^17.4.3",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "oxlint-tsgolint": "^0.23.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8",
    "zod": "^4.4.3"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "msw",
      "sharp"
    ],
    "overrides": {
      "cssstyle": "6.0.2",
      "ioredis": "5.11.0"
    }
  }
}
