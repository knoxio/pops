{
  "name": "@pops/monorepo",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "lint": "oxlint --type-aware",
    "lint:fix": "oxlint --type-aware --fix",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "ci:fix": "pnpm lint:fix && pnpm format && pnpm typecheck",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.51.0",
    "oxlint-tsgolint": "^0.21.1",
    "turbo": "^2.9.6"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "oxlint --fix",
      "oxfmt --write"
    ],
    "*.{json,md,css}": [
      "oxfmt --write"
    ]
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "msw",
      "sharp"
    ],
    "overrides": {
      "cssstyle": "6.0.2"
    }
  }
}
