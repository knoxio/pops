{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "isolatedModules": true,
    "noEmit": true,
    "paths": {
      "@ui/*": ["./src/*"]
    },
    "types": []
  },
  "include": ["src"],
  "exclude": ["node_modules", "src/**/*.test.*"]
}
