{
  "name": "@pops/api-client",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format:check": "oxfmt -c ../../.oxfmtrc.json --check \"src/**/*.ts\"",
    "format:fix": "oxfmt -c ../../.oxfmtrc.json --write \"src/**/*.ts\"",
    "test": "echo \"(no tests in @pops/api-client)\"",
    "ci:fix": "pnpm format:fix && pnpm lint:fix && pnpm typecheck && pnpm format:check && pnpm lint"
  },
  "dependencies": {
    "@pops/api": "workspace:*",
    "@trpc/client": "11.16.0",
    "@trpc/react-query": "11.16.0"
  },
  "devDependencies": {
    "eslint": "^10.2.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  }
}
