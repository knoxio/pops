{
  "name": "@pops/tools",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "oxfmt -c ../../.oxfmtrc.json --check src",
    "format:check": "oxfmt -c ../../.oxfmtrc.json --check src",
    "format:fix": "oxfmt -c ../../.oxfmtrc.json --write src",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "ci": "pnpm typecheck && pnpm lint && pnpm format:check && pnpm test",
    "ci:fix": "pnpm lint:fix && pnpm format:fix && pnpm typecheck && pnpm lint && pnpm format:check",
    "import:anz": "tsx src/import-anz.ts",
    "import:amex": "tsx src/import-amex.ts",
    "import:ing": "tsx src/import-ing.ts",
    "import:up": "tsx src/import-up-batch.ts",
    "match:transfers": "tsx src/match-transfers.ts",
    "match:novated": "tsx src/match-novated.ts",
    "entities:create": "tsx src/create-entities.ts",
    "entities:lookup": "tsx src/regenerate-entity-lookup.ts",
    "audit": "tsx src/audit.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.89.0",
    "better-sqlite3": "^12.9.0",
    "csv-parse": "^6.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.12.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.5.0",
    "tsx": "^4.19.0",
    "typescript": "^6.0.0",
    "vitest": "^4.1.4"
  }
}
