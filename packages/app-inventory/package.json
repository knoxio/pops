{
  "name": "@pops/app-inventory",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format:check": "oxfmt -c ../../.oxfmtrc.json --check \"src/**/*.{ts,tsx}\"",
    "format:fix": "oxfmt -c ../../.oxfmtrc.json --write \"src/**/*.{ts,tsx}\"",
    "ci:fix": "pnpm format:fix && pnpm lint:fix && pnpm typecheck && pnpm format:check && pnpm lint"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@pops/api-client": "workspace:*",
    "@pops/navigation": "workspace:*",
    "@pops/ui": "workspace:*",
    "@tanstack/react-query": "5.99.0",
    "@tanstack/react-table": "^8.21.3",
    "browser-image-compression": "^2.0.2",
    "d3-force": "^3.0.0",
    "heic2any": "^0.0.4",
    "lucide-react": "^1.8.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.72.1",
    "react-markdown": "^10.1.0",
    "react-router": "^7.14.1",
    "recharts": "^3.8.1",
    "rehype-sanitize": "^6.0.0",
    "sonner": "^2.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/d3-force": "^3.0.10",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^10.2.0",
    "jsdom": "^29.0.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.4"
  }
}
