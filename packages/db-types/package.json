{
  "name": "@pops/db-types",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema/index.d.ts",
      "default": "./dist/schema/index.js"
    },
    "./row-schemas": {
      "types": "./dist/schema/row-schemas.d.ts",
      "default": "./dist/schema/row-schemas.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch --preserveWatchOutput",
    "typecheck": "tsc --noEmit",
    "gen:row-schemas": "node scripts/gen-row-schemas.mjs",
    "lint:row-schemas": "node scripts/gen-row-schemas.mjs --check",
    "test": "echo \"(no tests in @pops/db-types)\""
  },
  "dependencies": {
    "@pops/media-db": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "typescript": "^6.0.3"
  }
}
