{
  "name": "@pops/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/router.ts",
      "default": "./src/router.ts"
    },
    "./modules/finance/imports": {
      "types": "./src/modules/finance/imports/types.ts",
      "default": "./src/modules/finance/imports/types.ts"
    },
    "./modules/core/corrections/service": {
      "types": "./src/modules/core/corrections/service.ts",
      "default": "./src/modules/core/corrections/service.ts"
    },
    "./modules/core/corrections/pure-service": {
      "types": "./src/modules/core/corrections/pure-service.ts",
      "default": "./src/modules/core/corrections/pure-service.ts"
    },
    "./modules/core/corrections/types": {
      "types": "./src/modules/core/corrections/types.ts",
      "default": "./src/modules/core/corrections/types.ts"
    },
    "./modules/core/tag-rules/types": {
      "types": "./src/modules/core/tag-rules/types.ts",
      "default": "./src/modules/core/tag-rules/types.ts"
    },
    "./modules/core/entities/types": {
      "types": "./src/modules/core/entities/types.ts",
      "default": "./src/modules/core/entities/types.ts"
    },
    "./modules/finance/transactions/types": {
      "types": "./src/modules/finance/transactions/types.ts",
      "default": "./src/modules/finance/transactions/types.ts"
    },
    "./modules/finance/budgets/types": {
      "types": "./src/modules/finance/budgets/types.ts",
      "default": "./src/modules/finance/budgets/types.ts"
    },
    "./modules/inventory/items/types": {
      "types": "./src/modules/inventory/items/types.ts",
      "default": "./src/modules/inventory/items/types.ts"
    },
    "./modules/inventory/connections/types": {
      "types": "./src/modules/inventory/connections/types.ts",
      "default": "./src/modules/inventory/connections/types.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch --clear-screen=false src/index.ts",
    "dev:init": "tsx scripts/init-db.ts",
    "db:clear": "tsx scripts/db-clear.ts",
    "db:seed": "tsx scripts/db-seed.ts",
    "media:sync-images": "tsx scripts/sync-images.ts",
    "media:sync-metadata": "tsx scripts/sync-metadata.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:all": "vitest run && vitest run --config vitest.integration.config.ts",
    "test:watch": "vitest",
    "openapi:validate": "tsx scripts/validate-openapi.ts",
    "ego": "tsx src/cli/ego.ts",
    "mcp": "tsx src/mcp/server.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@pops/db-types": "workspace:*",
    "@pops/types": "workspace:*",
    "@trpc/client": "11.16.0",
    "@trpc/server": "^11.16.0",
    "better-sqlite3": "^12.9.0",
    "bullmq": "^5.75.2",
    "chokidar": "^5.0.0",
    "cron-parser": "^5.5.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "express": "^5.0.1",
    "express-rate-limit": "^8.3.2",
    "gray-matter": "^4.0.3",
    "helmet": "^8.0.0",
    "ioredis": "^5.10.1",
    "js-yaml": "^4.1.1",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^4.2.1",
    "pdf-parse": "^2.4.5",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "sharp": "^0.34.5",
    "smol-toml": "^1.6.1",
    "sqlite-vec": "^0.1.7",
    "swagger-ui-express": "^5.0.1",
    "trpc-to-openapi": "^3.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^5.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "@types/node-cron": "^3.0.11",
    "@types/papaparse": "^5.5.2",
    "@types/pdf-parse": "^1.1.5",
    "@types/supertest": "^6.0.3",
    "@types/swagger-ui-express": "^4.1.8",
    "drizzle-kit": "^0.31.10",
    "msw": "^2.13.4",
    "papaparse": "^5.5.3",
    "supertest": "^7.2.2",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
