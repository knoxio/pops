{
  "name": "@pops/core",
  "version": "0.1.0",
  "private": true,
  "files": [
    "dist/contract/**",
    "openapi/core.openapi.json"
  ],
  "type": "module",
  "main": "./dist/contract/index.js",
  "types": "./dist/contract/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/contract/index.d.ts",
      "default": "./dist/contract/index.js"
    },
    "./api-types": {
      "types": "./dist/contract/api-types.generated.d.ts",
      "default": "./dist/contract/api-types.generated.js"
    },
    "./openapi": "./openapi/core.openapi.json",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc && tsx scripts/generate-openapi.ts && tsx scripts/generate-api-types.ts",
    "dev": "tsx watch --clear-screen=false src/api/server.ts",
    "start": "node dist/api/server.js",
    "typecheck": "tsc --noEmit && tsc --noEmit -p scripts/tsconfig.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "generate:openapi": "tsx scripts/generate-openapi.ts",
    "generate:api-types": "tsx scripts/generate-api-types.ts"
  },
  "dependencies": {
    "@pops/cerebrum-db": "workspace:*",
    "@pops/pillar-sdk": "workspace:*",
    "@pops/types": "workspace:*",
    "@trpc/server": "^11.17.0",
    "@ts-rest/core": "3.53.0-rc.1",
    "@ts-rest/express": "3.53.0-rc.1",
    "@ts-rest/open-api": "3.53.0-rc.1",
    "better-sqlite3": "^12.10.0",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.3",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@pops/wire-conformance": "workspace:*",
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^5.0.4",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.9.3",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.8",
    "openapi-typescript": "^7.13.0",
    "supertest": "^7.1.4",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
