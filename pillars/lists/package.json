{
  "name": "@pops/lists",
  "version": "0.1.0",
  "private": true,
  "files": [
    "dist/contract/**",
    "openapi/lists.openapi.json"
  ],
  "type": "module",
  "main": "./dist/contract/index.js",
  "types": "./dist/contract/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/contract/index.d.ts",
      "default": "./dist/contract/index.js"
    },
    "./manifest": {
      "types": "./dist/contract/manifest.d.ts",
      "default": "./dist/contract/manifest.js"
    },
    "./openapi": "./openapi/lists.openapi.json",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsx scripts/verify-manifest.ts && tsc && tsx scripts/generate-openapi.ts",
    "dev": "tsx watch --clear-screen=false src/api/server.ts",
    "start": "node dist/api/server.js",
    "typecheck": "tsc --noEmit && tsc --noEmit -p scripts/tsconfig.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "generate:manifest": "tsx scripts/generate-manifest.ts",
    "verify:manifest": "tsx scripts/verify-manifest.ts",
    "generate:openapi": "tsx scripts/generate-openapi.ts"
  },
  "dependencies": {
    "@pops/pillar-sdk": "workspace:*",
    "@pops/types": "workspace:*",
    "better-sqlite3": "^12.10.0",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "express": "^5.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^5.0.4",
    "@types/node": "^25.9.3",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.8",
    "supertest": "^7.1.4",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
