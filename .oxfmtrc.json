{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "semi": true,
  "singleQuote": true,
  "printWidth": 100,
  "tabWidth": 2,
  "useTabs": false,
  "trailingComma": "es5",
  "arrowParens": "always",
  "endOfLine": "lf",
  "sortImports": {
    "order": "asc",
    "ignoreCase": true,
    "newlinesBetween": true,
    "internalPattern": ["@pops/"],
    "groups": [
      "side_effect",
      "side_effect_style",
      "builtin",
      "external",
      ["internal", "subpath"],
      ["parent", "sibling", "index"],
      "style",
      "type-builtin",
      "type-external",
      ["type-internal", "type-subpath"],
      ["type-parent", "type-sibling", "type-index"],
      "unknown"
    ]
  },
  "ignorePatterns": [
    "node_modules",
    "dist",
    "coverage",
    "pnpm-lock.yaml",
    "package-lock.json",
    "*.csv",
    "*.jsonl",
    "**/*.tsbuildinfo",
    "**/*.min.js",
    "**/*.min.css",
    "**/*.map",
    "**/__snapshots__/**",
    "**/*.snap",
    "**/.turbo/**",
    "**/.vercel/**",
    ".github/**",
    ".vscode/**",
    "**/dist/**",
    "**/.next/**",
    "**/out/**",
    "**/build/**",
    "**/coverage/**",
    "**/playwright-report/**",
    "**/.vitest-reports/**",
    "**/test-results/**",
    "**/.nyc_output/**",
    "**/storybook-static/**"
  ]
}
