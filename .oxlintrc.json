{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "import", "react", "jsx-a11y", "unicorn"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "pedantic": "off",
    "perf": "warn"
  },
  "rules": {
    "max-lines": ["error", { "max": 200, "skipBlankLines": true, "skipComments": true }],
    "max-lines-per-function": [
      "error",
      { "max": 60, "skipBlankLines": true, "skipComments": true, "IIFEs": true }
    ],
    "complexity": ["error", 12],
    "max-statements": ["error", 160],
    "max-params": ["error", 4],
    "max-depth": ["error", 3],
    "no-console": ["error", { "allow": ["warn", "error"] }],
    "no-inline-comments": "off",
    "no-negated-condition": "off",
    "no-await-in-loop": "off",
    "no-nested-ternary": "error",
    "no-loop-func": "off",
    "no-shadow": "off",
    "no-throw-literal": "off",
    "no-unused-vars": "off",
    "require-await": "off",
    "consistent-return": "off",
    "import/no-duplicates": "off",
    "typescript/consistent-return": "off",
    "typescript/require-array-sort-compare": "off",
    "typescript/no-unnecessary-type-parameters": "off",
    "typescript/no-unnecessary-type-conversion": "off",
    "typescript/no-extraneous-class": "off",
    "typescript/await-thenable": "off",
    "jsx-a11y/prefer-tag-over-role": "off",
    "default-case": "off",
    "no-empty-function": "off",
    "no-useless-constructor": "off",
    "no-useless-rename": "off",
    "no-alert": "off",
    "no-new": "off",
    "no-extra-boolean-cast": "off",
    "prefer-promise-reject-errors": "off",
    "import/no-cycle": "off",
    "import/max-dependencies": "off",
    "import/no-unassigned-import": "off",
    "unicorn/no-array-callback-reference": "off",
    "unicorn/no-array-reduce": "off",
    "unicorn/no-useless-undefined": "off",
    "unicorn/no-negated-condition": "off",
    "unicorn/prefer-string-replace-all": "off",
    "unicorn/prefer-query-selector": "off",
    "unicorn/prefer-top-level-await": "off",
    "unicorn/prefer-module": "off",
    "unicorn/filename-case": "off",
    "unicorn/no-null": "off",
    "unicorn/consistent-function-scoping": "off",
    "unicorn/no-immediate-mutation": "off",
    "unicorn/prefer-array-find": "off",
    "unicorn/prefer-spread": "off",
    "unicorn/prefer-ternary": "off",
    "unicorn/prefer-set-has": "off",
    "unicorn/no-lonely-if": "off",
    "unicorn/catch-error-name": "off",
    "unicorn/prefer-code-point": "off",
    "unicorn/prefer-regexp-test": "off",
    "unicorn/prefer-number-properties": "off",
    "unicorn/throw-new-error": "off",
    "unicorn/escape-case": "off",
    "unicorn/no-hex-escape": "off",
    "unicorn/number-literal-case": "off",
    "unicorn/no-zero-fractions": "off",
    "unicorn/prefer-node-protocol": "off",
    "unicorn/prefer-type-error": "off",
    "unicorn/prefer-string-starts-ends-with": "off",
    "unicorn/prefer-string-slice": "off",
    "unicorn/prefer-includes": "off",
    "unicorn/prefer-date-now": "off",
    "unicorn/prefer-default-parameters": "off",
    "unicorn/no-useless-spread": "off",
    "unicorn/no-unreadable-array-destructuring": "off",
    "unicorn/prefer-dom-node-dataset": "off",
    "unicorn/prefer-dom-node-append": "off",
    "unicorn/prefer-dom-node-remove": "off",
    "unicorn/prefer-dom-node-text-content": "off",
    "unicorn/prefer-logical-operator-over-ternary": "off",
    "unicorn/prefer-optional-catch-binding": "off",
    "unicorn/no-useless-promise-resolve-reject": "off",
    "unicorn/prefer-math-trunc": "off",
    "unicorn/prefer-event-target": "off",
    "unicorn/prefer-add-event-listener": "off",
    "unicorn/prefer-native-coercion-functions": "off",
    "unicorn/no-abusive-eslint-disable": "off",
    "unicorn/numeric-separators-style": "off",
    "unicorn/error-message": "off",
    "typescript/no-explicit-any": "error",
    "typescript/no-non-null-assertion": "error",
    "typescript/prefer-nullish-coalescing": "warn",
    "typescript/explicit-function-return-type": [
      "error",
      {
        "allowExpressions": true,
        "allowTypedFunctionExpressions": true,
        "allowHigherOrderFunctions": true
      }
    ],
    "typescript/no-unused-vars": [
      "error",
      {
        "argsIgnorePattern": "^_",
        "varsIgnorePattern": "^_",
        "caughtErrorsIgnorePattern": "^_",
        "ignoreRestSiblings": true
      }
    ],
    "typescript/consistent-type-imports": [
      "error",
      { "prefer": "type-imports", "disallowTypeAnnotations": false }
    ],
    "typescript/no-unsafe-type-assertion": "off",
    "typescript/no-unsafe-assignment": "off",
    "typescript/no-unsafe-member-access": "off",
    "typescript/no-unsafe-call": "off",
    "typescript/no-unsafe-return": "off",
    "typescript/no-unsafe-argument": "off",
    "typescript/prefer-readonly-parameter-types": "off",
    "typescript/strict-boolean-expressions": "off",
    "typescript/strict-void-return": "off",
    "typescript/require-await": "off",
    "typescript/no-misused-promises": "off",
    "typescript/no-floating-promises": "off",
    "typescript/no-base-to-string": "off",
    "typescript/no-unnecessary-condition": "off",
    "typescript/prefer-optional-chain": "off",
    "typescript/no-confusing-void-expression": "off",
    "typescript/no-redundant-type-constituents": "off",
    "typescript/restrict-plus-operands": "off",
    "typescript/restrict-template-expressions": "off",
    "typescript/unbound-method": "off",
    "typescript/no-implied-eval": "off",
    "typescript/no-meaningless-void-operator": "off",
    "typescript/no-unnecessary-type-arguments": "off",
    "typescript/no-unnecessary-type-assertion": "off",
    "typescript/non-nullable-type-assertion-style": "off",
    "typescript/prefer-reduce-type-parameter": "off",
    "typescript/prefer-return-this-type": "off",
    "typescript/prefer-string-starts-ends-with": "off",
    "typescript/prefer-includes": "off",
    "typescript/prefer-find": "off",
    "typescript/prefer-for-of": "off",
    "typescript/dot-notation": "off",
    "typescript/no-array-delete": "off",
    "typescript/only-throw-error": "off",
    "typescript/use-unknown-in-catch-callback-variable": "off",
    "typescript/no-empty-object-type": "off",
    "typescript/consistent-type-exports": "off",
    "typescript/consistent-type-definitions": "off",
    "typescript/consistent-indexed-object-style": "off",
    "typescript/consistent-generic-constructors": "off",
    "typescript/array-type": "off",
    "typescript/no-inferrable-types": "off",
    "typescript/prefer-function-type": "off",
    "typescript/no-dynamic-delete": "off",
    "typescript/no-require-imports": "off",
    "typescript/no-invalid-void-type": "off",
    "typescript/no-non-null-asserted-nullish-coalescing": "off",
    "typescript/prefer-literal-enum-member": "off",
    "typescript/consistent-type-assertions": "off",
    "typescript/ban-ts-comment": "off",
    "typescript/no-empty-interface": "off",
    "typescript/no-namespace": "off",
    "typescript/no-useless-default-assignment": "off",
    "react/jsx-key": "error",
    "react/no-array-index-key": "warn",
    "react/no-children-prop": "error",
    "react/no-danger": "warn",
    "react/self-closing-comp": "error",
    "react/no-unescaped-entities": "off",
    "react/button-has-type": "off",
    "react/jsx-no-useless-fragment": "off",
    "react/no-unknown-property": "off",
    "react-hooks/rules-of-hooks": "error",
    "react-hooks/exhaustive-deps": "warn",
    "react/react-in-jsx-scope": "off",
    "jsx-a11y/alt-text": "off",
    "jsx-a11y/aria-role": "off",
    "jsx-a11y/click-events-have-key-events": "off",
    "jsx-a11y/no-autofocus": "off",
    "jsx-a11y/no-static-element-interactions": "off",
    "jsx-a11y/role-has-required-aria-props": "off",
    "jsx-a11y/role-supports-aria-props": "off",
    "jsx-a11y/label-has-associated-control": "off",
    "jsx-a11y/anchor-is-valid": "off",
    "jsx-a11y/img-redundant-alt": "off",
    "jsx-a11y/heading-has-content": "off",
    "jsx-a11y/anchor-has-content": "off",
    "jsx-a11y/tabindex-no-positive": "off",
    "eqeqeq": "off"
  },
  "overrides": [
    {
      "files": ["apps/pops-api/src/**/*.{ts,tsx}"],
      "rules": {
        "max-lines": ["error", { "max": 600, "skipBlankLines": true, "skipComments": true }],
        "max-lines-per-function": [
          "error",
          { "max": 200, "skipBlankLines": true, "skipComments": true, "IIFEs": true }
        ],
        "complexity": ["error", 30],
        "max-depth": ["error", 4],
        "max-params": ["error", 8],
        "typescript/explicit-function-return-type": [
          "error",
          {
            "allowExpressions": true,
            "allowTypedFunctionExpressions": true,
            "allowHigherOrderFunctions": true
          }
        ],
        "typescript/no-floating-promises": "error"
      }
    },
    {
      "files": ["packages/import-tools/src/**/*.ts"],
      "rules": {
        "no-console": "off",
        "max-lines": ["error", { "max": 400, "skipBlankLines": true, "skipComments": true }],
        "max-lines-per-function": [
          "error",
          { "max": 200, "skipBlankLines": true, "skipComments": true, "IIFEs": true }
        ],
        "complexity": ["error", 20],
        "max-depth": ["error", 4],
        "typescript/explicit-function-return-type": "off",
        "typescript/require-await": "off",
        "typescript/no-unnecessary-type-assertion": "error",
        "typescript/no-floating-promises": "error"
      }
    },
    {
      "files": ["apps/pops-shell/src/**/*.{ts,tsx}"],
      "rules": {
        "max-lines": ["error", { "max": 600, "skipBlankLines": true, "skipComments": true }],
        "max-lines-per-function": [
          "error",
          { "max": 270, "skipBlankLines": true, "skipComments": true, "IIFEs": true }
        ],
        "complexity": ["error", 40],
        "max-depth": ["error", 4],
        "typescript/explicit-function-return-type": "off"
      }
    },
    {
      "files": ["packages/ui/src/**/*.{ts,tsx}"],
      "rules": {
        "max-lines": ["error", { "max": 400, "skipBlankLines": true, "skipComments": true }],
        "max-lines-per-function": [
          "error",
          { "max": 260, "skipBlankLines": true, "skipComments": true, "IIFEs": true }
        ],
        "complexity": ["error", 45],
        "max-depth": ["error", 4],
        "typescript/explicit-function-return-type": "off",
        "jsx-a11y/alt-text": "warn",
        "jsx-a11y/aria-role": "warn",
        "jsx-a11y/click-events-have-key-events": "warn"
      }
    },
    {
      "files": [
        "packages/app-*/src/components/**/*.{ts,tsx}",
        "packages/app-*/src/hooks/**/*.{ts,tsx}",
        "packages/app-*/src/store/**/*.{ts,tsx}",
        "packages/app-*/src/lib/**/*.{ts,tsx}",
        "packages/navigation/src/**/*.{ts,tsx}"
      ],
      "rules": {
        "max-lines": ["error", { "max": 500, "skipBlankLines": true, "skipComments": true }],
        "max-lines-per-function": [
          "error",
          { "max": 270, "skipBlankLines": true, "skipComments": true, "IIFEs": true }
        ],
        "complexity": ["error", 45],
        "max-depth": ["error", 4],
        "typescript/explicit-function-return-type": "off"
      }
    },
    {
      "files": ["packages/app-*/src/pages/**/*.{ts,tsx}"],
      "rules": {
        "max-lines": ["error", { "max": 800, "skipBlankLines": true, "skipComments": true }],
        "max-lines-per-function": [
          "error",
          { "max": 500, "skipBlankLines": true, "skipComments": true, "IIFEs": true }
        ],
        "complexity": ["error", 70],
        "max-depth": ["error", 4],
        "typescript/explicit-function-return-type": "off"
      }
    },
    {
      "files": [
        "packages/app-finance/src/components/imports/TagRuleProposalDialog.tsx",
        "packages/app-finance/src/components/imports/ProcessingStep.tsx",
        "packages/app-finance/src/components/imports/TransactionCard.tsx",
        "packages/app-finance/src/components/imports/FinalReviewStep.tsx",
        "packages/app-finance/src/components/imports/ReviewStep.tsx"
      ],
      "rules": {
        "max-lines": ["error", { "max": 850, "skipBlankLines": true, "skipComments": true }],
        "max-lines-per-function": [
          "error",
          { "max": 400, "skipBlankLines": true, "skipComments": true, "IIFEs": true }
        ],
        "complexity": ["error", 55],
        "max-depth": ["error", 4],
        "typescript/explicit-function-return-type": "off"
      }
    },
    {
      "files": ["apps/pops-api/src/db/schema.ts", "apps/pops-api/src/db/seeder.ts"],
      "rules": {
        "max-lines": "off",
        "max-lines-per-function": "off",
        "complexity": "off",
        "max-statements": "off",
        "max-params": "off",
        "max-depth": "off"
      }
    },
    {
      "files": [
        "**/*.test.{ts,tsx}",
        "**/*.spec.{ts,tsx}",
        "**/test-utils.ts",
        "**/test-utils.tsx",
        "**/test-setup.ts",
        "**/test-setup.tsx"
      ],
      "rules": {
        "max-lines": "off",
        "max-lines-per-function": "off",
        "complexity": "off",
        "max-statements": "off",
        "max-params": "off",
        "max-depth": "off",
        "no-console": "off",
        "typescript/no-explicit-any": "off",
        "typescript/no-non-null-assertion": "off",
        "typescript/explicit-function-return-type": "off",
        "typescript/no-floating-promises": "off"
      }
    },
    {
      "files": ["**/*.stories.{ts,tsx}"],
      "rules": {
        "max-lines": "off",
        "max-lines-per-function": "off",
        "complexity": "off",
        "max-depth": "off",
        "max-statements": "off",
        "no-console": "off",
        "react/no-array-index-key": "off",
        "react-hooks/rules-of-hooks": "off",
        "typescript/no-non-null-assertion": "off"
      }
    },
    {
      "files": [
        "apps/pops-api/scripts/**/*.ts",
        "apps/pops-shell/e2e/**/*.ts",
        "services/*/src/scripts/**/*.ts"
      ],
      "rules": {
        "max-lines": "off",
        "max-lines-per-function": "off",
        "complexity": "off",
        "max-depth": "off",
        "no-console": "off",
        "typescript/explicit-function-return-type": "off"
      }
    }
  ],
  "settings": {
    "react": {
      "version": "19.2"
    },
    "jsx-a11y": {
      "polymorphicPropName": "as"
    }
  },
  "env": {
    "browser": true,
    "node": true,
    "es2024": true
  },
  "ignorePatterns": [
    "node_modules",
    "dist",
    "build",
    ".next",
    "coverage",
    "playwright-report",
    "test-results",
    ".turbo",
    "storybook-static",
    "**/*.config.js",
    "**/*.config.mjs",
    "**/*.config.ts"
  ]
}
