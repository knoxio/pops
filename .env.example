# Copy to .env and fill in values. NEVER commit .env.
# In production, secrets are managed via Ansible Vault -> Docker secrets.

# Up Bank
UP_BANK_TOKEN=
UP_WEBHOOK_SECRET=

# Claude AI
CLAUDE_API_KEY=

# Telegram (Moltbot)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_ID=

# Finance API
FINANCE_API_KEY=

# Cloudflare
CLOUDFLARE_TUNNEL_TOKEN=

# Radarr (movie downloads)
RADARR_URL=
RADARR_API_KEY=

# Sonarr (TV show downloads)
SONARR_URL=
SONARR_API_KEY=

# Plex Media Server (optional — library sync)
PLEX_URL=
PLEX_TOKEN=

# Paperless-ngx (optional — document management)
PAPERLESS_URL=
PAPERLESS_TOKEN=

# Paths
SQLITE_PATH=./data/pops.db
