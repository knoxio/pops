# Copy to .env and fill in values. NEVER commit .env.
# In production, runtime secrets are written to ./secrets/<name> files and
# mounted into containers via Docker file-based secrets (see infra/docker-compose.yml).
# Server-side provisioning + ansible vault live in knoxio/homelab-infra.

# Up Bank
UP_BANK_TOKEN=
UP_WEBHOOK_SECRET=

# Claude AI
CLAUDE_API_KEY=

# Telegram (Moltbot)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_ID=

# Finance API
FINANCE_API_KEY=

# Cloudflare
CLOUDFLARE_TUNNEL_TOKEN=

# Media Metadata Providers
# TMDB: Get a Read-Access Token (v4 auth) from https://www.themoviedb.org/settings/api
TMDB_API_KEY=
# TheTVDB: Get an API Key from https://thetvdb.com/dashboard/account/apikey
THETVDB_API_KEY=

# Plex Media Server (optional — library sync)
PLEX_URL=
PLEX_TOKEN=

# Paperless-ngx (optional — document management)
PAPERLESS_BASE_URL=
PAPERLESS_API_TOKEN=

# Paths
SQLITE_PATH=./data/pops.db
# Cerebrum engram root (Markdown files on disk). Absolute path recommended.
ENGRAM_ROOT=./data/engrams

# Image rollout
# Pin a specific tag (e.g. POPS_IMAGE_TAG=sha-abc1234) to disable Watchtower
# auto-updates. Applies to all three pops containers: pops-api, pops-worker
# (shares the api image), and pops-shell. Default is `main` (latest from main).
POPS_IMAGE_TAG=main

# Watchtower (host docker config dir, used to pull from private GHCR if images are private)
DOCKER_CONFIG_DIR=/root/.docker
TZ=Australia/Melbourne
