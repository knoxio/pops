*.db
*.db-wal
*.db-shm
*.sqlite
*.sqlite-wal
*.sqlite-shm
*.sqlite3
*.sqlite3-wal
*.sqlite3-shm
# SQLite WAL-mode auxiliary files for extensionless databases
*-wal
*-shm
*.csv
entity_lookup.json
ai_entity_cache.json

# OS
.DS_Store

# IDE
.vscode/
.idea/
.obsidian/
.claude/

