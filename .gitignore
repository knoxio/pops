# Dependencies
node_modules/
package-lock.json

# Build output
dist/
# Bundled nginx render + watcher CLIs (pillars/shell, built in-image)
dist-scripts/
# tsc -b project-reference incremental build state
*.tsbuildinfo

# Rust build output (repo-root cargo workspace; members under pillars/ + libs/).
# Cargo.lock IS committed for the workspace (reproducible bin builds).
target/

# Environment and secrets
.env
.env.*
!.env.example
*.secret

